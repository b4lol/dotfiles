# -----------------------------------------------------
# ALIASES
# -----------------------------------------------------

# -----------------------------------------------------
# General
# -----------------------------------------------------
alias ..='cd ..'
alias c='clear'
alias nf='fastfetch'
alias pf='fastfetch'
alias ff='fastfetch'
alias ls='eza -a --icons=always'
alias ll='eza -al --icons=always'
alias lt='eza -a --tree --level=1 --icons=always'
alias shutdown='~/.config/secureblue/scripts/secureblue-power -p'
alias v='$EDITOR'
alias vim='$EDITOR'
alias wifi='nmtui'
alias arch-cleanup='~/.config/secureblue/scripts/arch/cleanup.sh'
alias apps='~/.config/secureblue/bin/secureblue-apps'
alias screenshot='~/.config/secureblue/bin/secureblue-screenshot'
alias updates='~/.config/secureblue/scripts/secureblue-install-system-updates'
alias filemanager='~/.config/secureblue/settings/filemanager'
alias autostart='~/.config/secureblue/scripts/secureblue-autostart'
alias lock='hyprlock'
alias clock='tty-clock'
alias system='~/.config/secureblue/settings/systemmonitor'
alias quick='~/.config/secureblue/bin/secureblue-quicklinks'
alias wallpaper='~/.config/secureblue/bin/secureblue-wallpaper'
alias settings='secureblue-dotfiles-settings com.secureblue.dotfiles'

# -----------------------------------------------------
# SECUREBLUE Apps
# -----------------------------------------------------
alias secureblue='qs ipc call welcome toggle'
alias secureblue-settings='qs -p ~/.local/share/secureblue-dotfiles-settings/quickshell ipc call settings toggle'
alias secureblue-calendar='qs ipc call calendar toggle'
alias secureblue-hyprland='flatpak run com.secureblue.hyprlandsettings'
alias secureblue-sidebar='qs ipc call sidebar toggle'

# -----------------------------------------------------
# Git
# -----------------------------------------------------
alias gs="git status"
alias ga="git add"
alias gc="git commit -m"
alias gp="git push"
alias gpl="git pull"
alias gst="git stash"
alias gsp="git stash; git pull"
alias gfo="git fetch origin"
alias gcheck="git checkout"
alias gcredential="git config credential.helper store"

# -----------------------------------------------------
# Scripts
# -----------------------------------------------------
alias ascii='~/.config/secureblue/scripts/secureblue-ascii-header'

# -----------------------------------------------------
# System
# -----------------------------------------------------
alias update-grub='sudo grub-mkconfig -o /boot/grub/grub.cfg'

